(defalias
  ;; -----------------------------
  ;; Base combos first
  ;; -----------------------------
  hypur (multi lalt lctl lmet lsft)
  meh   (multi lalt lctl lsft)
  AC    (multi lalt lctl)
  AS    (multi lalt lsft)
  AMS   (multi lalt lmet lsft)
  CS    (multi lctl lsft)
  CMS   (multi lctl lmet lsft)
  MS    (multi lmet lsft)
  MSa   (multi @MS a)
  tabal (multi lalt tab)
  force (multi lalt lmet esc)

  ;; -----------------------------
  ;; Raycast/app aliases used by others
  ;; -----------------------------
  mtrsh (cmd open "raycast://extensions/raycast/system/empty-trash")
  rayai (cmd open "raycast://extensions/raycast/raycast-ai/ai-chat")
  rclip (cmd open "raycast://extensions/raycast/clipboard-history/clipboard-history")
  remoj (cmd open "raycast://extensions/raycast/emoji-symbols/search-emoji-symbols")
  rfile (cmd open "raycast://extensions/raycast/file-search/search-files")
  spot/ (cmd open "raycast://extensions/mattisssa/spotify-player/search")
  utbe/ (cmd open "raycast://extensions/tonka3000/youtube/search-videos?arguments=%7B%22query%22%3A%22%22%7D")

  ;; -----------------------------
  ;; Scam aliases
  ;; -----------------------------
  scam6 (multi @hypur 6)
  scam0 (multi @hypur 3)
  scamt (multi @hypur 4)
  scamh (multi @hypur h)
  scamw (multi @hypur w)
  scams (multi @hypur s)

  ;; -----------------------------
  ;; Home row mods
  ;; -----------------------------
  Hlctl (tap-hold $tt $ht a lctl)
  Hlalt (tap-hold $tt $ht d lalt)
  Hlmet (tap-hold $tt $ht f lmet)
  Hrmet (tap-hold $tt $ht j rmet)
  Hralt (tap-hold $tt $ht k ralt)
  Hrctl (tap-hold $tt $ht ; lctl)

  ;; -----------------------------
  ;; Double-action keys
  ;; -----------------------------
  caltb (tap-hold $tt $ht @tabal @AC)
  grasc (tap-hold $tt $ht grv @CS)
  hyper (tap-hold $tt $ht f18 @hypur)
  mehsc (tap-hold $tt $ht esc @meh)
  mhome (tap-hold $tt $ht e @scam6)
  shalt (tap-hold $tt $ht @scam0 @AS)
  shdel (tap-hold $tt $ht del rsft)
  suXMS (tap-hold $tt $ht @force @CMS)
  trams (tap-hold $tt $ht @mtrsh @AMS)
  tabSG (tap-hold $tt $ht tab @MS)
  ytfnd (tap-hold $tt $ht [ @utbe/)
  zmute (tap-hold $tt $ht ' @MSa)

  ;; -----------------------------
  ;; Layer entry aliases
  ;; -----------------------------
  subly (tap-hold-press $subl-t $subl-t ret (layer-while-held sublayers))
  capps (tap-hold-press $subl-t $subl-t caps (layer-while-held applications))
  rycst (tap-hold-press $subl-t $subl-t p (layer-while-held raycast))
  yabam (tap-hold-press $subl-t $subl-t lsft (layer-while-held yabai))
  ;;  lemld (tap-hold-press $subl-t $subl-t lsft (layer-while-held meld))

  ;; -----------------------------
  ;; Yabai window management
  ;; -----------------------------
  yfwes (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus west")
  yfsth (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus south")
  yfnth (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus north")
  yfeas (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus east")
  yswes (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap west")
  yssth (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap south")
  ysnth (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap north")
  yseas (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap east")
  ywinx (cmd sudo -u $(whoami) zsh -lc "yabai -m window --close")
  ymirr (cmd sudo -u $(whoami) zsh -lc "yabai -m space --mirror y-axis")

  ;; -----------------------------
  ;; System actions
  ;; -----------------------------
  smute (cmd sudo -u $(whoami) zsh -lc "$RX/mic-mute.sh")
  calnx (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/calendar-next-meeting.sh")
  csnxt (cmd sudo -u $(whoami) zsh -lc "$LB/colorswitch-next")

  ;; -----------------------------
  ;; Kitty session jumps
  ;; -----------------------------
  kdock (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:docker 2>/dev/null || open -a kitty")
  dotsh (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:dotfiles 2>/dev/null || open -a kitty")
  khome (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:home 2>/dev/null || open -a kitty")
  knvim (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:nvim 2>/dev/null || open -a kitty")
  kpodc (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:podcast 2>/dev/null || open -a kitty")
  kssh2 (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:ssh-2mini 2>/dev/null || open -a kitty")

  ;; -----------------------------
  ;; Focus modes
  ;; -----------------------------
  fopod (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/focus/podcast-host.sh")
  forec (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/focus/recording-mode.sh")
  dotsy (cmd sudo -u $(whoami) zsh -lc "$RX/dots-sync.sh")

  ;; -----------------------------
  ;; App switching
  ;; -----------------------------
  calen (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Calendar")
  cshot (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'CleanShot X'")
  prevu (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Preview")
  affin (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'Affinity'")
  findr (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Finder")
  pages (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Pages")
  comet (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Comet")
  dvstu (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'DaVinci Resolve'")
  rnmgr (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'Name Mangler'")
  dkshn (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Dictionary")
  obsid (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Obsidian")
  disco (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Discord")
  claud (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Claude")
  spoti (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Spotify")
  notes (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Notes")
  syset (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'System Settings'")
  mldst (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'Meld Studio'")
  safri (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Safari")
  kitty (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh kitty")
  wtsap (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh WhatsApp")
  mesgs (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Messages")
)
