;;----------------------------------------------------
;; aliases.kbd — included by macos.kbd
;; All (cmd ...) calls run as root when kanata is a LaunchDaemon.
;; app-switch.sh resolves the real console user internally via /dev/console,
;; so no sudo -u needed here.
;;----------------------------------------------------

(defalias
  ;;-------------------------------------------------------
  ;; Hyper / SCAM shortcuts (used by other apps)
  ;;-------------------------------------------------------
  scam6 S-C-A-M-6           ;; homerow trigger
  scam0 S-C-A-M-s           ;; cleanshot capture area
  scamt S-C-A-M-tab         ;; cleanshot capture history
  scamw S-C-A-M-w           ;; cleanshot capture window

  ;;-------------------------------------------------------
  ;; Yabai window management
  ;;-------------------------------------------------------
  yfws (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus west")
  yfso (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus south")
  yfno (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus north")
  yfea (cmd sudo -u $(whoami) zsh -lc "yabai -m window --focus east")
  ysws (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap west")
  ysso (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap south")
  ysno (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap north")
  ysea (cmd sudo -u $(whoami) zsh -lc "yabai -m window --swap east")
  ywnx (cmd sudo -u $(whoami) zsh -lc "yabai -m window --close")
  ymir (cmd sudo -u $(whoami) zsh -lc "yabai -m space --mirror y-axis")
  
  ;;-------------------------------------------------------
  ;; App switching
  ;; Physical key positions are QWERTY; Dvorak chars shown in comments
  ;;-------------------------------------------------------

  ;; going to test/try sublayers to not have to map multiple layer keys
  ;; subl (tap-hold-press $subl-time $subl-time ret (layer-while-held sublayers))
  ;; lapp (tap-hold-press $subl-time $subl-time bspc (layer-while-held applications))

  ;; Terminal / dev
  akit (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh kitty")          ;; physical `i` = Dvorak `c` (top row)

  ;; Browsers
  acmt (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Comet")          ;; physical `o` = Dvorak `r` (top row)
  asaf (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Safari")         ;; physical `x` = Dvorak `q` (bottom row)

  ;; Productivity / notes
  obsi (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Obsidian")       ;; physical `s` = Dvorak `o`  (home row)
  anot (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Notes")          ;; physical `l` = Dvorak `n` (top row)
  apag (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Pages")          ;; physical `u` = Dvorak `g` (top row)
  acal (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Calendar")       ;; physical `0` = Dvorak `0`
  acla (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Claude")         ;; physical `h` = Dvorak `d`  (home row)
  ames (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Messages")       ;; physical `,` = Dvorak `w` (top row)
  awha (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh WhatsApp")       ;; physical `.` = Dvorak `v` (bottom row)
  adic (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Dictionary")     ;; physical `[` = Dvorak `/` (bottom row)
  anmg (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'Name Mangler'") ;; physical `]` = Dvorak `=`

  ;; Media / creative
  aspt (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Spotify")        ;; physical `p` = Dvorak `l` (top row)
  advs (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'DaVinci Resolve'") ;; physical `h` = Dvorak `d`  (home row)
  acsh (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'CleanShot X'")  ;; physical `e` = Dvorak `.` (top row)
  afin (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'Affinity'")     ;; physical `q` = Dvorak `'` (top row)
  amld (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'Meld Studio'")  ;; physical `z` = Dvorak `;` (bottom row)

  ;; System / utils
  afnd (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Finder")         ;; physical `y` = Dvorak `f` (top row)
  apre (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Preview")        ;; physical `r` = Dvorak `p` (top row)
  asys (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh 'System Settings'") ;; physical `;` = Dvorak `s`  (home row)
  adis (cmd sudo -u $(whoami) zsh -lc "$RX/app-switch.sh Discord")        ;; physical `d` = Dvorak `e`  (home row)

  ;; Dotfiles sync
  dots (cmd sudo -u $(whoami) zsh -lc "$RX/dots-sync.sh")

  ;;-------------------------------------------------------
  ;; System actions
  ;;-------------------------------------------------------
  smut (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/mic-mute.sh")
  slrl (macro (cmd sudo -u $(whoami) zsh -lc "osascript -e 'display notification \"Reloading kanata\" with title \"Kanata\"'") 500 lrld)
  acnm  (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/calendar-next-meeting.sh")  ;; calendar + open meeting

  ;;-------------------------------------------------------
  ;; Focus modes
  ;;-------------------------------------------------------
  Fpod (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/focus/podcast-host.sh")
  Frec (cmd sudo -u $(whoami) zsh -lc "$HOME/.config/rx/focus/recording-mode.sh")

  ;;-------------------------------------------------------
  ;; Raycast utilities (still useful even without Raycast app alias)
  ;;-------------------------------------------------------
  trsh  (cmd open "raycast://extensions/raycast/system/empty-trash")
  yt/   (cmd open "raycast://extensions/tonka3000/youtube/search-videos?arguments=%7B%22query%22%3A%22%22%7D")

  ;;-------------------------------------------------------
  ;; HOME ROW MODS
  ;; a=lctl  d=lalt  f=lmet  |  j=rmet  k=ralt  ;=rctl
  ;;-------------------------------------------------------
  mlct (tap-hold $tt $ht a lctl)
  mlal (tap-hold $tt $ht d lalt)
  mlme (tap-hold $tt $ht f lmet)
  mrme (tap-hold $tt $ht j rmet)
  mral (tap-hold $tt $ht k ralt)
  mrct (tap-hold $tt $ht ; lctl)
  rmut (tap-hold $tt $ht ' (multi lmet lsft a))  ;; lmet+lsft+a → zoom mute toggle

  ;;-------------------------------------------------------
  ;; DOUBLE-ACTION KEYS
  ;;-------------------------------------------------------
  ;; entm (tap-hold $tt $ht ret (layer-while-held raycast))
  ;; myba (tap-hold $subl-time $subl-time rmet (layer-while-held yabai-manage))
  gcs  (tap-hold $tt $ht grv (multi lctl lsft))
  lHYP (tap-hold $tt $ht f18 (multi lsft lctl lalt lmet))
  mehc (tap-hold $tt $ht esc (multi lsft lctl lalt))
  mhom (tap-hold $tt $ht e @scam6)
  myts (tap-hold $tt $ht [ @yt/)
  mets (tap-hold $tt $ht (multi lmet lalt esc) (multi lalt lctl lmet))
  btab (tap-hold $tt $ht (multi lalt tab) (multi lalt lmet))
  tams (tap-hold $tt $ht @trsh (multi rmet ralt lsft))
  shdl (tap-hold $tt $ht del rsft)
  shal (tap-hold $tt $ht f13 (multi lsft lalt))
  tbSG (tap-hold $tt $ht tab (multi lsft lmet))
)

;;-------------------------------------------------------
;; RAYCAST COMMANDS
;;-------------------------------------------------------
(defalias
  remj (cmd open "raycast://extensions/raycast/emoji-symbols/search-emoji-symbols")
  rfil (cmd open "raycast://extensions/raycast/file-search/search-files")
  rspt (cmd open "raycast://extensions/mattisssa/spotify-player/search")
  rvid (cmd open "raycast://extensions/tonka3000/youtube/search-videos?arguments=%7B%22query%22%3A%22%22%7D")
  rclp (cmd open "raycast://extensions/raycast/clipboard-history/clipboard-history")
  rayi (cmd open "raycast://extensions/raycast/raycast-ai/ai-chat")
)

;;-------------------------------------------------------
;; KITTY SESSION JUMPS
;;-------------------------------------------------------
(defalias
  khom (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:home 2>/dev/null || open -a kitty")
  kdot (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:dotfiles 2>/dev/null || open -a kitty")
  knvm (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:nvim 2>/dev/null || open -a kitty")
  kaut (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:automation 2>/dev/null || open -a kitty")
  kpod (cmd sudo -u $(whoami) zsh -lc "kitten @ focus-window --match title:podcast 2>/dev/null || open -a kitty")
)

;;-------------------------------------------------------
;; COLORSCHEME CYCLE
;;-------------------------------------------------------
(defalias
  acol (cmd sudo -u $(whoami) zsh -lc "$LB/colorswitch-next")
)
