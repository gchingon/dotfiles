;; --- ALIASES (The core logic) ---
(defalias
;; hyper<->scam
  scam6 S-C-A-M-6     ;; homerow
  scam0 S-C-A-M-0     ;; cleanshot capture area
  scamt S-C-A-M-tab   ;; cleanshot capture history
  scamw S-C-A-M-w     ;; cleanshot capture window

;; key replacements
  ;; cros  (unicode †)
  2spc (macro spc spc)

;; aliases for commands
  abtt (cmd zsh -lc "$RX/app-switch.sh BetterTouchTool")
  acld (cmd zsh -lc "$RX/app-switch.sh claude")
  adis (cmd zsh -lc "$RX/app-switch.sh discord")
  advs (cmd zsh -lc "$RX/app-switch.sh 'Davinci Resolve Studio'")
  afnd (cmd zsh -lc "$RX/app-switch.sh finder")
  amld (cmd zsh -lc "$RX/app-switch.sh 'meld studio'")
  anot (cmd zsh -lc "$RX/app-switch.sh notes")
  aobs (cmd zsh -lc "$RX/app-switch.sh obsidian")
  apag (cmd zsh -lc "$RX/app-switch.sh pages")
  apre (cmd zsh -lc "$RX/app-switch.sh preview")
  asaf (cmd zsh -lc "$RX/app-switch.sh safari")
  asoc (cmd zsh -lc "$RX/app-switch.sh socialstream")
  aspo (cmd zsh -lc "$RX/app-switch.sh spotify")
  asys (cmd zsh -lc "$RX/app-switch.sh 'System Settings'")
  awez (cmd zsh -lc "$RX/app-switch.sh wezterm")
  azom (cmd zsh -lc "$RX/app-switch.sh zoom")
  trsh (cmd open "raycast://extensions/raycast/system/empty-trash")
  wtl6 (cmd open "raycast://extensions/raycast/window-management/top-left-sixth")
  wtr6 (cmd open "raycast://extensions/raycast/window-management/top-right-sixth")
  wtl4 (cmd open "raycast://extensions/raycast/window-management/top-left-quarter")
  wtr4 (cmd open "raycast://extensions/raycast/window-management/top-right-quarter")
  wbl6 (cmd open "raycast://extensions/raycast/window-management/bottom-left-sixth")
  wbr6 (cmd open "raycast://extensions/raycast/window-management/bottom-right-sixth")
  wbl4 (cmd open "raycast://extensions/raycast/window-management/bottom-left-quarter")
  wbr4 (cmd open "raycast://extensions/raycast/window-management/bottom-right-quarter")
  wcnt (cmd open "raycast://extensions/raycast/window-management/center-half")

;; Modifier keys HOME ROW MODS
  mlctl (tap-hold $tt $ht a rctl)
  mlalt (tap-hold $tt $ht d lalt)
  mlmet (tap-hold $tt $ht f lmet)
  mrmet (tap-hold $tt $ht j rmet)
  mralt (tap-hold $tt $ht k ralt)
  mrctl (tap-hold $tt $ht ; lctl)

;; Double actions,.
  lHYP    (tap-hold-press $tt $ht f18 (multi lsft lctl lalt lmet))
  mehsc   (tap-hold-press $tt $ht esc (multi lsft lctl lalt))
  mhome   (tap-dance 200 ((tap-hold $tt 170 e @scam6) (one-shot-press 1500 (layer-while-held symb))))
  altgrv  (tap-hold-press $tt $ht k @mralt)
  rtaplt  (tap-hold-press $tt 240 @trsh (multi rmet ralt))
  shdel   (tap-hold-press $tt $ht del rsft)                   ;; DELETE an tap, SHIFT on hold
  shalt   (tap-hold-press $tt 240 (macro C-; i) (multi lsft lalt))  ;; wezterm COPY MODE on tap, SHFT+ALT on hold
  tabSG   (tap-hold-press $tt $ht tab (multi lsft lmet))            ;; makes screenshot shortcuts and raycast CONFIG APP easier

;; --- Advanced Modifier Remaps ---

;; Other layers tap-hold-press
  mappr (tap-dance 200 (spc (one-shot-press 1500 (layer-while-held apps))))
  msymb (tap-hold $tt $ht esc (layer-toggle symb))
  mnavi (tap-hold-press $tt $ht lmet (layer-toggle navi))
)
