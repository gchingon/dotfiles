;; --- MAIN KEYMAP LAYER (77 keys) ---
(deflayer base
  ;; Top Row (F-Keys)
  _    _    _    _    _    _    _    _    _    _    _    _   _ 

  ;; Number Row
  _    _    _    _    _    _    _    _    _    _    _    _    _    _

  ;; QWERTY Row
  @tab-meh _    _    _    _    _    _    _    _    _    _    _    _    _

  ;; Home Row
  @caps-hyper _    _    _    _    _    _    _    _    _    _    _    @ret-rctl

  ;; Bottom Row (zxc...)
  _    _    _    _    _    _    _    _    _    _    _    _    @rshift-fdel

  ;; Modifier/Arrow Row
  _    _    _    _             spc            _    @ralt-dance _    _    _
)
