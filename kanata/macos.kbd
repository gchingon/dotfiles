;;----------------------------------------------------
;; macos.kbd — Kanata config for macOS (all machines)
;; Dvorak keyboard layout — physical QWERTY positions
;; Runs as LaunchDaemon (root).
;; app-switch.sh resolves real user internally via /dev/console.
;;
;; LAYER MAP:
;;   main         — daily typing, home row mods
;;   apps         — app switching (hold lmet via @metsc)
;;   raycast      — raycast + kitty session jumps (hold enter)
;;   yabai-manage — window management (hold rmet)
;;----------------------------------------------------

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold   yes
  danger-enable-cmd     yes
)

(include aliases.kbd)

;;----------------------------------------------------
;; Variables
;;----------------------------------------------------
(defvar
 tap-higher 400
 tt 300
 ht 300
 chord-time 60
 subl-time 300  ;; sublayer hold — longer = fewer accidents
)

;;----------------------------------------------------
;; defsrc — 77-key MacBook physical layout
;; Order MUST match all deflayer declarations exactly.
;; These are hardware key positions, not Dvorak chars.
;;----------------------------------------------------
(defsrc
  esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  grv  1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab  q    w    e    r    t    y    u    i    o    p    [    ]    \
  caps a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft z    x    c    v    b    n    m    ,    .    /    up   rsft
  fn   lctl lalt lmet           spc            rmet ralt left down rght
)

;;----------------------------------------------------
;; MAIN layer
;;
;; Physical → Dvorak reference for modified keys:
;;   caps → esc (tap) / MEH (hold)
;;   grv  → `/Ctrl+Shift
;;   a → a/lctl    s → o/lalt    d → e/lalt
;;   f → u/lmet    g → i         h → d
;;   j → h/rmet    k → t/ralt    l → n
;;   ; → s/rctl    ' → -
;;   e → ./HOMEROW  [ → [/YT-search
;;   tab → tab/Shift+GUI    ret → ret/raycast layer
;;   spc → spc
;;   del → del/rsft         btab → alt+tab/alt+GUI
;;   rght → empty-trash/GUI+Alt+Shift
;;   lHYP → HYPER (f18 tap, Hyper hold)
;;----------------------------------------------------
(deflayer main
  _      brdn   brup   f3     f4     f5     f6     prev   pp     next   mute   vold   volu          ;; EscFn
  @gcs   1      2      3      4      5      6      7      8      9      0      _      _      _      ;; 1-0
  @tbSG  _      _      @mhom  _      _      _      _      _      _      _      @myts  _      _      ;; Q\  
  @mehc  @mlct  _      @mlal  @mlme  _      _      @mrme  @mral  _      @mrct  _      _             ;; A'  
  _      _      _      _      _      _      _      _      _      _      _      _      @shdl         ;; Z/  
  fn     @btab  @shal  @mets          spc          @lHYP  @tams  _      _      _                    ;; MOD 
)

;;(deflayer sublayers
;;  ;;     a      s      d      f      g      h      j      k      l      ;      '
;;  XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX            ;; EscFn
;;  XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     @lapp  ;; 1-0
;;  XX     XX     @lwor  XX     @lray  @less  XX     XX     XX     @meld  XX     XX     XX     XX     ;; Q\
;;  XX     XX     @lets  XX     XX     XX     XX     XX     XX     XX     XX     XX     XX            ;; A'
;;  XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX     XX            ;; Z/
;;  XX     XX     XX     @mapps         XX                  XX     XX     XX     XX     XX            ;; MOD
;;)

;;----------------------------------------------------
;; APPS layer — app switching
;; Activated by: hold lmet (via @mets)
;;
;; Physical key → Dvorak char → App
;;   0  → 0 → Calendar        (@acal)
;; QWERTY row:
;;   e  → . → CleanShot X     (@acsh)
;;   r  → p → Preview         (@apre)
;;   t  → y → Affinity        (@afin)
;;   y  → f → Finder          (@afnd)
;;   u  → g → Pages           (@apag)
;;   i  → c → Comet           (@acmt)
;;   p  → l → Spotify         (@aspt)
;;   [  → / → Dictionary      (@adic)
;;   ]  → = → Name Mangler    (@anmg)
;; Home row:
;;   a  → a → Obsidian        (@obsi)
;;   d  → e → Discord         (@adis)
;;   f  → u → colorscheme next(@acol)
;;   h  → d → DaVinci Resolve (@advs)
;;   j  → h → Claude          (@acla)
;;   l  → n → Notes           (@anot)
;;   ;  → s → System Settings (@asys)
;; Bottom row:
;;   z  →   → Meld Studio     (@amld)
;;   x  → q → Safari          (@asaf)
;;   v  → k → kitty           (@akit)
;;   m  → m → Messages        (@ames)
;;   ,  → w → WhatsApp        (@awha)
;;   n  → b → dots-sync       (@dots)
;; Modifier row:
;;   left/down/rght → arrow passthrough
;;----------------------------------------------------
;;(deflayer applications
;;  _    XX     XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX
;;  grv  1      2     3     4     5     6     7     8     9     @acal _     _     del
;;  _    _      _     @acsh @apre @afin @afnd @apag @acmt @aspt @adic @anmg _     _
;;  _    @obsi  @adis @acol _     @advs @acla _     @anot @asys _     _     _
;;  lsft @amld  @asaf _     @akit @dots _     @ames @awha _     _     up    rsft  ;; Bottom Row
;;  fn   lctl   lalt  lmet           spc            rmet  ralt  left  down  rght
;;)
;;
;;----------------------------------------------------
;; RAYCAST + KITTY-SESSIONS layer
;; Activated by: hold enter (via @entm)
;;
;; Requires in kitty.conf:
;;   allow_remote_control yes
;;   listen_on unix:/tmp/kitty
;;
;; Kitty session jumps (physical hjkl area — upper row):
;;   Physical w → Dvorak , → dotfiles  (@kdot)
;;   Physical e → Dvorak . → nvim      (@knvm)
;;   Physical r → Dvorak p → automation(@kaut)
;;   Physical t → Dvorak y → podcast   (@kpod)
;;   Physical i → Dvorak c → home      (@khom)
;;
;; Raycast — Home row:
;;   a → a → ai chat    (@rayi)
;;   s → o → emoji      (@remj)
;;   d → e → clipboard  (@rclp)
;;   f → u → file search(@rfil)
;;   ' → - → zoom mute  (@rmut)
;;
;; Bottom row:
;;   c → j → Spotify search   (@rspot)
;;   v → k → YouTube search   (@rvide)
;;----------------------------------------------------
;;(deflayer raycast
;;  _     XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX
;;  grv   1     2     3     4     5     6     7     8     9     0     _     _     del
;;  _     _     @kdot @knvm @kaut @kpod XX    XX    @khom XX    XX    XX    XX    XX
;;  XX    @rayi @remj @rclp @rfil XX    _     XX    XX    XX    XX    @rmut XX
;;  XX    XX    XX    @rspt @rvid XX    XX    XX    XX    XX    XX    XX    XX    ;; Bottom Row
;;  fn    lctl  lalt  lmet           spc            rmet  ralt  left  down  rght
;;)
;;
;;----------------------------------------------------
;; YABAI-MANAGE layer — window management
;; Activated by: hold esc (via @myba)
;;
;; Physical hjkl → focus/swap directions:
;;   h → focus west    j → focus south
;;   k → focus north   l → focus east
;;   Shift+hjkl        → swap versions
;;   n → mirror y-axis
;;   bspc → close window
;;----------------------------------------------------
;;(deflayer yabai-manage
;;  _     XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX
;;  grv   1     2     3     4     5     6     7     8     9     0     _     _     @ywnx
;;  _     XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX
;;  XX    XX    XX    XX    XX    XX    @yfws @yfso @yfno @yfea XX    XX    XX
;;  XX    XX    XX    XX    XX    @ymir @ysws @ysso @ysno @ysea XX    XX    XX    ;; Bottom Row
;;  fn    lctl  lalt  lmet           spc            rmet  ralt  left  down  rght
;;)
;;
