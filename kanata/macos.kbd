  ;;----------------------------------------------------
  ;; macos.kbd — Kanata config for macOS (all machines) Dvorak keyboard layout — physical QWERTY positions
  ;; Runs as LaunchDaemon (root). app-switch.sh resolves real user internally via /dev/console.
  ;; LAYER MAP:
  ;;   main         — daily typing, home row mods
  ;;   apps         — app switching (hold `s`)
  ;;   raycast      — raycast + kitty session jumps (hold `c`)
  ;;   yabai-manage — window management (hold enter)
  ;;----------------------------------------------------

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold   yes
  danger-enable-cmd     yes
)

(include aliases.kbd)

  ;;----------------------------------------------------
  ;; Variables
  ;;----------------------------------------------------
(defvar
  tap-higher 400
  tt 300
  ht 300
  kord-t 60
  subl-t 500  ;; sublayer hold — longer = fewer accidents
)

  ;;----------------------------------------------------
  ;; defsrc — 77-key MacBook physical layout Order MUST match all deflayer declarations exactly. These are hardware key positions, not Dvorak chars.
  ;;----------------------------------------------------
(defsrc
  esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  grv  1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab  q    w    e    r    t    y    u    i    o    p    [    ]    \
  caps a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft z    x    c    v    b    n    m    ,    .    /    up   rsft
  fn   lctl lalt lmet           spc            rmet ralt left down rght
)

  ;;----------------------------------------------------
  ;; MAIN layer      
  ;;----------------------------------------------------
(deflayer main
  esc    brdn   brup   f3     f4     f5     f6     prev   pp     next   mute   vold   volu         ;; EscFn
  @grasc 1      2      3      4      5      6      7      8      9      0      _      _      _     ;; NUM
  @tabSG _      _      @mhome _      _      _      _      _      _      _      _      _      _     ;; QWERTY
  @mehsc @Hlctl _      @Hlalt @Hlmet _      _      @Hrmet @Hralt _      @Hrctl _      _            ;; HOME  
  _      _      _      _      _      _      _      _      _      _      _      _      @shdel       ;; BOTTOM
  fn     @caltb @shalt @suXMS          spc         @hyper @trams _      _      _                   ;; MOD 
)

  ;; @lemld layer needs to be designed/written
  ;;----------------------------------------------------
  ;; APPS layer/switching Activated by: (hold `s`)
  ;; Physical → Dvorak  → Application     (alias)   ;; row
  ;;   6      →   6     → Meld Studio     (@mldst)  ;; NUM    7      →   7     → colorscheme next(@csnxt)  ;; NUM    
  ;;   8      →   8     → Name Mangler    (@rnmgr)  ;; NUM    9      →   9     → Dictionary      (@dkshn)  ;; NUM    
  ;;   0      →   0     → Calendar        (@calen)  ;; NUM    
  ;;   e      →   .     → CleanShot X     (@cshot)  ;; QWERTY   r    →   p     → Preview         (@prevu)  ;; QWERTY   
  ;;   t      →   y     → Affinity        (@affin)  ;; QWERTY   y    →   f     → Finder          (@findr)  ;; QWERTY   
  ;;   u      →   g     → Pages           (@pages)  ;; QWERTY   i    →   c     → Comet           (@comet)  ;; QWERTY   
  ;;   o      →   r     → DaVinci Resolve (@dvstu)  ;; QWERTY   p    →   l     → Spotify         (@spoti)  ;; QWERTY   
  ;;   j      →   h     → Obsidian        (@obsid)  ;; HOME   d      →   e     → Discord         (@disco)  ;; HOME
  ;;   h      →   d     → Claude          (@claud)  ;; HOME   l      →   n     → Notes           (@notes)  ;; HOME
  ;;   ;      →   s     → System Settings (@syset)  ;; HOME   x      →   q     → Safari          (@safri)  ;; BOTTOM
  ;;   v      →   k     → kitty           (@kitty)  ;; BOTTOM   m    →   m     → Messages        (@mesgs)  ;; BOTTOM
  ;;   ,      →   w     → WhatsApp        (@wtsap)  ;; BOTTOM
  ;;----------------------------------------------------

  ;;----------------------------------------------------
  ;; RAYCAST + KITTY-SESSIONS layer Activated by: hold `c` (via @rycst)
  ;; Requires in kitty.conf:
  ;;   allow_remote_control yes, listen_on unix:/tmp/kitty
  ;; Kitty session jumps (physical hjkl area — upper row):
  ;;  Physical →    Dvorak    →    APP         (@alias)
  ;;     w     →       ,      →    dotfiles    (@dotsh)   e     →       .      →    nvim        (@knvim)   
  ;;     r     →       p      →    docker      (@kdock)   t     →       y      →    podcast     (@kpodc)   
  ;;     i     →       c      →    home        (@khome)   ]     →       =      → Spotify search (@sptfd)   
  ;;     x     →       x      →    ssh2mini    (@kssh2)   
  ;; Raycast
  ;;     a     →       a      →    ai chat     (@rayai)   s     →       o      →    emoji       (@remoj)   
  ;;     d     →       e      →    clipboard   (@rclip)   f     →       u      →    file search (@rfile)   
  ;;     '     →       -      →    zoom mute   (@zmute)   v     →       k      → YouTube search (@tbefd)   
  ;;----------------------------------------------------
(deflayer raycast
  _     XX     XX     XX     XX     XX     XX    XX     XX     XX    XX     XX     XX            ;; EscFn
  grv   1      2      3      4      5      6     7      8      9     0      _      _      del    ;; NUM
  _     _      @dotsh @knvim @kdock @kpodc XX    XX     XX     XX    @tbefd XX    XX     XX     ;; QWERTY
  XX    _      _      _      _      XX     _     XX     @khome XX    @sptfd XX    XX            ;; HOME
  XX    XX     XX     XX     XX     XX     XX    @zmute XX     XX    XX     XX     XX            ;; BOTTOM
  fn    lctl   lalt   lmet           spc         rmet   ralt  left   down   rght                 ;; MOD
)

  ;;----------------------------------------------------
