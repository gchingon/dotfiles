;;----------------------------------------------------
;; App-switching aliases — platform-conditional
;; Used by: deflayer apps
;; Pattern: caps+u chord to enter layer, tap target → focus or launch app
;;----------------------------------------------------

(platform (macos)
  (defalias
    a-afnt (cmd zsh -lc "$RX/app-switch.sh 'Affinity Designer'")
    a-cale (cmd zsh -lc "$RX/app-switch.sh Calendar")
    a-clau (cmd zsh -lc "$RX/app-switch.sh Claude")
    a-codx (cmd zsh -lc "$RX/app-switch.sh Codex")
    a-comt (cmd zsh -lc "$RX/app-switch.sh Comet")
    a-dict (cmd zsh -lc "$RX/app-switch.sh Dictionary")
    a-find (cmd zsh -lc "$RX/app-switch.sh Finder")
    a-msgs (cmd zsh -lc "$RX/app-switch.sh Messages")
    a-note (cmd zsh -lc "$RX/app-switch.sh Notes")
    a-obsi (cmd zsh -lc "$RX/app-switch.sh Obsidian")
    a-pass (cmd zsh -lc "$RX/app-switch.sh Passwords")
    a-prev (cmd zsh -lc "$RX/app-switch.sh Preview")
    a-sfri (cmd zsh -lc "$RX/app-switch.sh Safari")
    a-spot (cmd zsh -lc "$RX/app-switch.sh Spotify")
    a-sset (cmd zsh -lc "$RX/app-switch.sh 'System Settings'")
    a-davr (cmd zsh -lc "$RX/app-switch.sh 'DaVinci Resolve'")
    a-term (cmd zsh -lc "$RX/app-switch.sh kitty")
    a-what (cmd zsh -lc "$RX/app-switch.sh WhatsApp")
  )
)

(platform (linux)
  (defalias
    a-term (cmd bash -c "wmctrl -xa kitty || kitty &")
    a-brws (cmd bash -c "wmctrl -xa firefox || firefox &")
    a-obsi (cmd bash -c "wmctrl -xa obsidian || obsidian &")
    a-clau (cmd bash -c "wmctrl -xa claude || claude &")
    a-find (cmd bash -c "wmctrl -xa thunar || thunar &")
    a-disc (cmd bash -c "wmctrl -xa discord || discord &")
    a-spot (cmd bash -c "wmctrl -xa spotify || spotify &")
    a-cale (cmd bash -c "wmctrl -xa gnome-calendar || gnome-calendar &")
    a-what (cmd bash -c "wmctrl -xa whatsapp || xdg-open 'https://web.whatsapp.com' &")
    a-msgs (cmd bash -c "echo 'no messages client configured'")
    a-prev (cmd bash -c "echo 'no preview client configured'")
    a-davr (cmd bash -c "wmctrl -xa resolve || /opt/resolve/bin/resolve &")
    a-note (cmd bash -c "wmctrl -xa notes || xdg-open 'https://keep.google.com' &")
    a-sset (cmd bash -c "wmctrl -xa gnome-control-center || gnome-control-center &")
    a-meld (cmd bash -c "echo 'Meld Studio macOS only'")
    a-pass (cmd bash -c "wmctrl -xa 1password || 1password &")
  )
)
