;;   _    _     _     _     _     _     _     _     _     _     _     _     _     _          ;; NUM
;;   _    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX         ;; QWERTY
;;   XX   XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX               ;; HOME
;;   XX   XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX               ;; BOTTOM
;;   fn   lctl  lalt  lmet        spc        rmet  ralt  left  down  rght                   ;; MOD
;; )
;;----------------------------------------------------
