;;----------------------------------------------------
;; kanata.kbd — Cross-platform Kanata config
;; Dvorak keyboard layout on physical QWERTY positions
;; Runs as LaunchDaemon (macOS) or systemd unit (Linux)
;;
;; LAYER MAP:
;;   main    — daily typing, home row mods
;;   apps    — app switching         (tab+0 chord, one-shot 3s)
;;   system  — system controls       (tab+[ chord, one-shot 3s)
;;   raycast — raycast + kitty jumps (tab+] chord, one-shot 3s)
;;   emoji   — quick emoji           (double-tap Esc)
;;----------------------------------------------------

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold   yes
  danger-enable-cmd     yes
  chords-v2-min-idle    80
)

;;----------------------------------------------------
;; Variables
;;----------------------------------------------------
(defvar
  tap-higher 400
  tt 300
  ht 300
  kord-t 500
  subl-t 500

  ;; Absolute paths — kanata runs as root LaunchDaemon so $HOME = /var/root.
  ;; These defvar values are substituted at parse time, before cmd reaches the shell.
  UH /Users/schingon
  CF (concat $UH /.config)
  RX (concat $CF /rx)
  LB (concat $UH /.local/bin)
)

;;----------------------------------------------------
;; Includes — alias files with platform blocks inside
;;----------------------------------------------------
(include aliases-shared.kbd)
(include aliases-apps.kbd)
(include aliases-kitty.kbd)
(include aliases-system.kbd)
(include aliases-raycast.kbd)
(include aliases-emoji.kbd)

;;----------------------------------------------------
;; Sublayer entry — chords activate layers
;; tab+0 → apps (one-shot 3s)   tab+[ → system (one-shot 3s)
;; tab+] → raycast (one-shot 3s)
;; Chord timeout $kord-t = 500ms; release condition = all-released
;;----------------------------------------------------
(defchordsv2
  (tab 2) (one-shot 3000 (layer-while-held apps))    $kord-t all-released ()
  (tab 3) (one-shot 3000 (layer-while-held raycast)) $kord-t all-released ()
  (tab 4) (one-shot 3000 (layer-while-held system))  $kord-t all-released ()
)

;;----------------------------------------------------
;; Return: tap = ret, double-tap = kitty
;; (defined after includes so @a-term is available)
;;----------------------------------------------------
(defalias
  retkt (tap-dance 200 (ret @a-term))
)

;;----------------------------------------------------
;; defsrc — 77-key MacBook physical layout
;; Order MUST match all deflayer declarations exactly.
;; These are hardware key positions, not Dvorak chars.
;;----------------------------------------------------
(defsrc
  esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  grv  1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab  q    w    e    r    t    y    u    i    o    p    [    ]    \
  caps a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft z    x    c    v    b    n    m    ,    .    /    up   rsft
  fn   lctl lalt lmet           spc            rmet ralt left down rght
)

;;----------------------------------------------------
;; MAIN layer — daily typing, home row mods
;; Physical positions → Dvorak output via process-unmapped-keys
;;
;; tab+0 chord → apps layer (one-shot 3s)
;; tab+[ chord → system layer (one-shot 3s)
;; tab+] chord → raycast layer (one-shot 3s)
;; Esc = tap esc / double-tap → emoji layer (one-shot)
;; Return = tap ret / double-tap → open kitty
;;----------------------------------------------------
(deflayer main
  @escem brdn    brup    f3      f4      f5      f6      prev    pp      next    mute    vold    volu          ;; Fn row
  @grasc 1       2       3       4       5       6       7       8       9       0       _       _       _     ;; NUM
  @tabSG _       _       @mhome  _       _       _       _       _       _       _       _       _       _     ;; QWERTY
  @mehsc @Hlctl  _       @Hlalt  @Hlmet  _       _       @Hrmet  @Hralt  _       @Hrctl  _       @retkt        ;; HOME
  lsft   _       _       _       _       _       _       _       _       _       _       _       @shdel        ;; BOTTOM
  fn     @caltb  @shalt  @suXMS            spc           @hyper  @trams  _       _       _                     ;; MOD
)

;;----------------------------------------------------
;; APPS layer — app switching
;; Activated by: caps+u chord (one-shot 3s)
;;
;; Physical → App (a-* aliases in aliases-apps.kbd)
;;   QWERTY: e=Passwords  r=Dictionary  t=Preview  y=SystemSettings
;;           u=Affinity   i=Calendar   o=DaVinci
;;   HOME:   a=Claude  s=Codex  f=Finder  j=Comet  k=Safari  l=Notes  ;=Spotify
;;   BOTTOM: m=Messages  ,=WhatsApp
;;----------------------------------------------------
(deflayer apps
  _      _       _       _       _       _       _       _       _       _       _       _       _             ;; Fn
  _      1       2       3       4       5       6       7       8       9       0       _       _       _     ;; NUM
  _      _       _       @a-pass @a-dict @a-prev @a-sset @a-afnt @a-cale @a-davr _       _       _       _     ;; QWERTY
  _      _       _       @a-obsi @a-find @a-sfri @a-comt _       _       @a-note @a-spot _       _             ;; HOME
  _      _       _       _       @a-codx _       @a-clau @a-msgs @a-what _       _       _       _             ;; BOTTOM
  _      _       _       _                 _             _       _       _       _       _                     ;; MOD
)

;;----------------------------------------------------
;; RAYCAST layer — Raycast utilities + kitty session jumps
;; Activated by: caps+m chord (one-shot 3s)
;;
;; QWERTY e–o → kitty sessions:
;;   e=dotfiles  r=nvim  t=docker  y=podcast  u=home  i=ssh2  o=ssh4
;; HOME a–k → Raycast utilities:
;;   a=AI  s=Clipboard  d=Files  f=Emoji  g=Spotify  h=YouTube  j=Trash  k=ZoomMute
;;----------------------------------------------------
(deflayer raycast
  _       XX      XX      XX      XX      XX      XX      XX      XX      XX      XX      XX      XX           ;; Fn
  grv     1       2       3       4       5       6       7       8       9       0       _       _      _     ;; NUM
  _       XX      XX      @k-dots @k-nvim @k-dckr @k-podc @k-home @k-ssh2 @k-ssh4 XX      _       _      _     ;; QWERTY
  _       @rayai  @rclip  @rfile  @remoj  @sptfd  @tbefd  @mtrsh  @zmute  XX      XX      _       _             ;; HOME
  _       XX      XX      XX      XX      XX      XX      XX      _       _       _       _       _             ;; BOTTOM
  _       _       _       _              _                _       _       _       _       _                     ;; MOD
)

;;----------------------------------------------------
;; SYSTEM layer — system controls
;; Activated by: caps+; chord (one-shot 3s)
;;
;; Physical → Action (sys-* aliases in aliases-system.kbd)
;;   u = Audio          i = Wifi          o = Bluetooth
;;   p = Screenshot
;;   j = Activity       k = Share/AirDrop l = Mic mute
;;   ; = Lock screen
;;   m = Next meeting   , = Dots sync     . = Colorscheme next
;;----------------------------------------------------
(deflayer system
  _      XX      XX      XX      XX      XX      XX       XX       XX       XX       XX       XX     XX           ;; Fn
  grv    XX      XX      XX      XX      XX      XX       XX       XX       XX       XX       _      _      _     ;; NUM
  _      XX      XX      XX      XX      XX      XX       @sys-aud @sys-wfi @sys-blu @sys-cap _      _      _     ;; QWERTY
  _      XX      XX      XX      XX      _       XX       @sys-act @sys-shr @sys-mic @sys-lok _      _             ;; HOME
  _      XX      XX      XX      XX      XX      XX       @sys-cal @sys-dot @sys-col XX       _      _             ;; BOTTOM
  _      _       _       _              _                _        _        _        _        _                    ;; MOD
)

;;----------------------------------------------------
;; EMOJI layer — quick emoji output
;; Activated by: double-tap Esc (one-shot)
;; Single tap esc = esc, double-tap = emoji one-shot
;;
;; Physical key → emoji (see aliases-emoji.kbd for codepoints):
;;   1 = 💯
;;   q = 🤯  w = 🤞  e = 🙄  r = 🤘  t = 🥂  y = 🖕  o = 👌
;;   a = 💪  s = 😄  d = 🤤  f = 🙏  h = ❤️  j = 😂  k = 😘  l = 😍
;;   c = 🎉  n = 👎  m = 💰
;;----------------------------------------------------
(deflayer emoji
  _      XX      XX      XX      XX      XX      XX      XX      XX      XX      XX      XX      XX           ;; Fn
  _      @em-100 _       _       _       _       _       _       _       _       _       _       _       _    ;; NUM
  _      @em-blo @em-wsh @em-eye @em-rck @em-tst @em-flp XX      XX      @em-ok  XX      XX      XX      XX    ;; QWERTY
  _      @em-flx @em-sml @em-drl @em-pry XX      @em-hrt @em-cry @em-kis @em-lov XX      XX      XX            ;; HOME
  _      XX      XX      @em-cel XX      XX      @em-no  @em-mny XX      XX      XX      XX      XX            ;; BOTTOM
  _      _       _       _              _               _       _       _       _       _                     ;; MOD
)

