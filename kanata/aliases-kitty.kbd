;;----------------------------------------------------
;; Kitty session jumps — platform-conditional
;; Used by: deflayer raycast
;;
;; Uses kitty-session.sh which:
;;   1. Parses session file for the ACTUAL tab title (may differ from filename).
;;   2. Focuses an existing tab by that title via kitten @ focus-tab.
;;   3. Creates a new tab from the session file if kitty is running.
;;   4. Launches kitty with --session if kitty is not running.
;;
;; Requires in kitty.conf:
;;   allow_remote_control yes
;;   listen_on unix:/tmp/kitty
;;
;; Session files live in ~/.config/kitty/sessions/<name>.kitty-session
;; NOTE: $RX is a kanata defvar = /Users/schingon/.config/rx
;;       This is needed because kanata runs as root (LaunchDaemon)
;;       where shell $HOME = /var/root.
;;----------------------------------------------------

(platform (macos)
  (defalias
    k-dots (cmd zsh -lc "$RX/kitty-session.sh dots")
    k-nots (cmd zsh -lc "$RX/kitty-session.sh docs")
    k-nvim (cmd zsh -lc "$RX/kitty-session.sh nvim")
    k-dckr (cmd zsh -lc "$RX/kitty-session.sh automation")
    k-podc (cmd zsh -lc "$RX/kitty-session.sh podcast")
    k-home (cmd zsh -lc "$RX/kitty-session.sh home")
    k-ssh2 (cmd zsh -lc "$RX/kitty-session.sh ssh-2mini")
    k-ssh4 (cmd zsh -lc "$RX/kitty-session.sh ssh-4mini")
  )
)

(platform (linux)
  (defalias
    k-dots (cmd bash -c "$RX/kitty-session.sh dots")
    k-nots (cmd bash -c "$RX/kitty-session.sh docs")
    k-nvim (cmd bash -c "$RX/kitty-session.sh nvim")
    k-dckr (cmd bash -c "$RX/kitty-session.sh automation")
    k-podc (cmd bash -c "$RX/kitty-session.sh podcast")
    k-home (cmd bash -c "$RX/kitty-session.sh home")
    k-ssh2 (cmd bash -c "$RX/kitty-session.sh ssh-2mini")
    k-ssh4 (cmd bash -c "$RX/kitty-session.sh ssh-4mini")
  )
)
