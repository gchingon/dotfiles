;;----------------------------------------------------
;; APPS layer — app switching Activated by: hold lmet (via @metsc)
;; Physical key → Dvorak char → App
;;   0  → 0  → Calendar         (@acal)
;; QWERTY row:
;;   e  → .  → CleanShot X      (@acsh)
;;   r  → p  → Preview          (@apre)
;;   t  → y  → Affinity         (@afin)
;;   y  → f  → Finder           (@afnd)
;;   u  → g  → Pages            (@apag)
;;   i  → c  → Comet            (@acmt)
;;   p  → l  → Spotify          (@aspt)
;;   [  → /  → Dictionary       (@adic)
;;   ]  → =  → Name Mangler     (@anmg)
;; Home row:
;;   a  → a  → Obsidian         (@obsi)
;;   d  → e  → Discord          (@adis)
;;   f  → u  → colorscheme next (@acol)
;;   h  → d  → DaVinci Resolve  (@advs)
;;   j  → h  → Claude           (@acla)
;;   l  → n  → Notes            (@anot)
;;   ;  → s  → System Settings  (@asys)
;; Bottom row:
;;   v  → k  → kitty            (@akit)
;;   m  → m  → Messages         (@ames)
;;   ,  → w  → WhatsApp         (@awha)
;;   n  → b  → dots-sync        (@dots)
;; Modifier row:
;;   left/down/rght → arrow passthrough
;;----------------------------------------------------
(deflayer apps
  _     XX   XX    XX    XX     XX     XX    XX    XX    XX    XX    XX    XX
  grv   1    2     3     4      5      6     7     8     9     @acal _     _     del
  _     _    _     @acsh @apre  @afin  @afnd @apag @acmt @aspt @adic @anmg _     _
  _     _    @obsi @adis @acol  _      @advs @acla _     @anot @asys _     _
  lsft  _    _     _     @akit  @dots  _     @ames @awha _     _     up    rsft         ;; Bottom Row
  fn    lctl lalt  lmet         spc        rmet  ralt  left  down  rght
)
