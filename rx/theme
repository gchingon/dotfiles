#!/usr/bin/env bash
# theme — Unified theme/color switcher for kitty, yazi, nvim
# Usage:
#   theme                    # Switch to next theme in rotation
#   theme <name>             # Set specific theme
#   theme --list|-l          # List available themes
#   theme --current|-c       # Show current theme
#   theme -h|--help          # Show help

source "$(dirname "$0")/lib/common.sh"
check_deps jq

THEME_DIR="${HOME}/.config/colors"
THEME_JSON="${THEME_DIR}/colors.json"
ACTIVE_FILE="${THEME_DIR}/active_theme.json"
KITTY_THEME="${HOME}/.config/kitty/theme.conf"
YAZI_THEME="${HOME}/.config/yazi/theme.toml"

# Get list of themes
list_themes() {
  jq -r '.themes | keys[]' "$THEME_JSON" 2>/dev/null || die "Cannot read $THEME_JSON"
}

# Get current theme
current_theme() {
  jq -r '.active // empty' "$ACTIVE_FILE" 2>/dev/null || list_themes | head -1
}

# Get next theme in rotation
next_theme() {
  local current="$(current_theme)"
  local themes=($(list_themes))
  local idx=0
  for i in "${!themes[@]}"; do
    [[ "${themes[$i]}" == "$current" ]] && idx=$i && break
  done
  echo "${themes[$(( (idx + 1) % ${#themes[@]} ))]}"
}

# Validate theme exists
theme_exists() {
  jq -e --arg t "$1" '.themes[$t] != null' "$THEME_JSON" >/dev/null
}

# Apply to kitty
apply_kitty() {
  local theme="$1"
  local outdir="$(dirname "$KITTY_THEME")"
  mkdir -p "$outdir"
  
  jq -r --arg t "$theme" '    .themes[$t].terminal as $g | if $g == null then empty else
    "# Auto-generated by theme. Do not edit.",
    "background " + $g.background, "foreground " + $g.foreground,
    "cursor " + $g.cursor, "color0 " + $g.color0, "color1 " + $g.color1,
    "color2 " + $g.color2, "color3 " + $g.color3, "color4 " + $g.color4,
    "color5 " + $g.color5, "color6 " + $g.color6, "color7 " + $g.color7,
    "color8 " + $g.color8, "color9 " + $g.color9, "color10 " + $g.color10,
    "color11 " + $g.color11, "color12 " + $g.color12, "color13 " + $g.color13,
    "color14 " + $g.color14, "color15 " + $g.color15 end'     "$THEME_JSON" > "$KITTY_THEME"
  
  # Live-apply if kitty is running
  if command -v kitty >/dev/null 2>&1; then
    kitty @ set-colors --all --configured "$KITTY_THEME" 2>/dev/null || true
  fi
}

# Apply to yazi
apply_yazi() {
  local theme="$1"
  local yazi_theme="$(jq -r --arg t "$theme" '.themes[$t].yazi.theme // empty' "$THEME_JSON")"
  [[ -z "$yazi_theme" || ! -f "$YAZI_THEME" ]] && return 0
  
  if grep -qE '^[[:space:]]*theme[[:space:]]*=' "$YAZI_THEME"; then
    sed -i.bak -E "s|theme = .*$|theme = "$yazi_theme"|" "$YAZI_THEME"
    rm -f "${YAZI_THEME}.bak"
  else
    echo "theme = "$yazi_theme"" >> "$YAZI_THEME"
  fi
}

# Nudge nvim to reload
nudge_nvim() {
  if [[ -n "${NVIM:-}" && -S "${NVIM}" ]]; then
    nvim --server "$NVIM" --remote-send ":lua require('core.theme').setup()<CR>" 2>/dev/null || true
  elif [[ -S "/tmp/nvim.sock" ]]; then
    nvim --server "/tmp/nvim.sock" --remote-send ":lua require('core.theme').setup()<CR>" 2>/dev/null || true
  fi
}

reload_sketchybar() {
  if command -v sketchybar >/dev/null 2>&1 && pgrep -x sketchybar >/dev/null 2>&1; then
    sketchybar --reload >/dev/null 2>&1 || true
  fi
}

# Main
case "${1:-}" in
  --help|-h)
    sed -n '2,8p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
    ;;
  --list|-l)
    list_themes
    exit 0
    ;;
  --current|-c)
    current_theme
    exit 0
    ;;
  "")
    # No arg = rotate to next theme
    theme="$(next_theme)"
    log "Switching to: $theme"
    ;;
  -*)
    die "Unknown option: $1"
    ;;
  *)
    theme="$1"
    theme_exists "$theme" || die "Theme not found: $theme"
    ;;
esac

# Apply theme
mkdir -p "$THEME_DIR"
printf '{"active": "%s"}\n' "$theme" > "$ACTIVE_FILE"
apply_kitty "$theme"
apply_yazi "$theme"
nudge_nvim
reload_sketchybar

echo "Theme: $theme"
